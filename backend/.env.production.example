# Production environment template.
# Copy to the server as backend/.env and fill in the real values.
#   cp .env.production.example .env
#   php artisan key:generate        # fills APP_KEY
# Never commit the filled-in file.

APP_NAME="Restaurant App"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example
APP_TIMEZONE=Europe/Chisinau

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en

# Keep production logs quiet; daily rotation.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# Database (the `db` service on the compose network).
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=restaurant_app
DB_USERNAME=restaurant_app
DB_PASSWORD=change-me-to-a-strong-password

# Driver choices (DB-backed; no extra services required).
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Telegram bot (from @BotFather). The webhook is registered automatically on
# container start from APP_URL + TELEGRAM_WEBHOOK_SECRET.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# WooCommerce REST API credentials (live menu items).
WOOCOMMERCE_CASTA_KEY=
WOOCOMMERCE_CASTA_SECRET=
WOOCOMMERCE_GRUZIA_KEY=
WOOCOMMERCE_GRUZIA_SECRET=

# Bearer tokens for the WooCommerce/WP reservations endpoint (calendar sync).
WOOCOMMERCE_CASTA_RESERVATIONS_TOKEN=
WOOCOMMERCE_GRUZIA_RESERVATIONS_TOKEN=

# Set both to the app's public origin (the domain in APP_URL, no trailing slash).
SANCTUM_STATEFUL_DOMAINS=your-domain.example
CORS_ALLOWED_ORIGINS=https://your-domain.example

# API token lifetime in minutes (default 7 days).
SANCTUM_TOKEN_EXPIRATION=10080

# Mail (configure if the app should send email; defaults to no-op log driver).
MAIL_MAILER=log
